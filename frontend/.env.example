# Pokerstarks Frontend Environment Variables

# Dojo World address (deployed via sozo migrate apply)
NEXT_PUBLIC_WORLD_ADDRESS=0x0

# Torii indexer URLs
NEXT_PUBLIC_TORII_URL=http://localhost:8080
NEXT_PUBLIC_TORII_RPC_URL=http://localhost:5050

# RPC URL for Cartridge Controller / wallet interactions
# For local dev: same as TORII_RPC_URL (Katana). For production: Sepolia/mainnet RPC.
NEXT_PUBLIC_RPC_URL=http://localhost:5050

# Torii relay for real-time subscriptions
NEXT_PUBLIC_RELAY_URL=

# Garaga calldata generation server
NEXT_PUBLIC_GARAGA_API_URL=http://localhost:3001

# Contract system addresses (set after sozo migrate apply)
NEXT_PUBLIC_LOBBY_ADDRESS=
NEXT_PUBLIC_GAME_SETUP_ADDRESS=
NEXT_PUBLIC_SHUFFLE_ADDRESS=
NEXT_PUBLIC_DEALING_ADDRESS=
NEXT_PUBLIC_BETTING_ADDRESS=
NEXT_PUBLIC_SHOWDOWN_ADDRESS=
NEXT_PUBLIC_SETTLE_ADDRESS=
