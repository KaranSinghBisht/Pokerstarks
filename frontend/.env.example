# Pokerstarks Frontend Environment Variables

# Dojo World address (deployed via sozo migrate apply)
NEXT_PUBLIC_WORLD_ADDRESS=0x0

# Torii indexer URLs
NEXT_PUBLIC_TORII_URL=http://localhost:8080
NEXT_PUBLIC_TORII_RPC_URL=http://localhost:5050

# RPC URL for Cartridge Controller / wallet interactions
# For local dev: same as TORII_RPC_URL (Katana). For production: Sepolia/mainnet RPC.
NEXT_PUBLIC_RPC_URL=http://localhost:5050

# Torii relay for real-time subscriptions
NEXT_PUBLIC_RELAY_URL=

# Garaga calldata generation server
NEXT_PUBLIC_GARAGA_API_URL=http://localhost:3001

# Contract system addresses (set after sozo migrate apply)
NEXT_PUBLIC_LOBBY_ADDRESS=
NEXT_PUBLIC_GAME_SETUP_ADDRESS=
NEXT_PUBLIC_SHUFFLE_ADDRESS=
NEXT_PUBLIC_DEALING_ADDRESS=
NEXT_PUBLIC_BETTING_ADDRESS=
NEXT_PUBLIC_SHOWDOWN_ADDRESS=
NEXT_PUBLIC_SETTLE_ADDRESS=
NEXT_PUBLIC_TIMEOUT_ADDRESS=
NEXT_PUBLIC_CHAT_ADDRESS=

# Garaga verifiers used by lobby.create_table
NEXT_PUBLIC_SHUFFLE_VERIFIER_ADDRESS=
NEXT_PUBLIC_DECRYPT_VERIFIER_ADDRESS=

# Persist per-hand secret keys in sessionStorage.
# SECURITY: Keep disabled unless you explicitly need refresh recovery.
NEXT_PUBLIC_PERSIST_SESSION_SECRET=false

# ─── Bot API Auth ───
# Shared secret to protect /api/bot/* routes from unauthorized access.
# Set BOT_API_SECRET (server-only) and NEXT_PUBLIC_BOT_API_SECRET (for browser calls) to the same value.
# If unset, routes are open (dev mode).
BOT_API_SECRET=
NEXT_PUBLIC_BOT_API_SECRET=

# ─── Bot Accounts (server-only, NOT prefixed with NEXT_PUBLIC_) ───
# Up to 4 bot accounts for "Fill With Bots" feature.
# Each needs a funded Starknet account (only gas, no tokens when token_address=0x0).
# Generate keypairs: starkli signer gen-keypair
BOT_PRIVATE_KEY_1=
BOT_ADDRESS_1=
BOT_PRIVATE_KEY_2=
BOT_ADDRESS_2=
BOT_PRIVATE_KEY_3=
BOT_ADDRESS_3=
BOT_PRIVATE_KEY_4=
BOT_ADDRESS_4=

# ─── Tongo Confidential Tokens ───
# Tongo contract for STRK on Sepolia (default provided, override if using custom deployment)
NEXT_PUBLIC_TONGO_STRK_ADDRESS=0x408163bfcfc2d76f34b444cb55e09dace5905cf84c0884e4637c2c0f06ab6ed
# STRK ERC20 token address on Sepolia
NEXT_PUBLIC_STRK_TOKEN_ADDRESS=0x4718f5a0fc34cc1af16a1cdee98ffb20c31f5cd61d6ab07201858f4287c938d
